{
    "extends": [
        "stylelint-config-standard"
    ],
    "rules": {
        "at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": [
                    "tailwind",
                    "apply",
                    "layer",
                    "config",
                    "screen",
                    "variants",
                    "responsive"
                ]
            }
        ],
        "import-notation": null,
        "color-hex-length": null
    }
}